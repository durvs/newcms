# Database
# Ports 5433/6380 are used to avoid clashing with locally installed
# Postgres/Redis; docker-compose maps them to the containers.
DB_HOST=localhost
DB_PORT=5433
DB_NAME=cms
DB_USER=cms
DB_PASSWORD=cms_password
DB_MAX_CONNECTIONS=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# Auth
# Pepper used for password hashing — change to a long random value in production.
AUTH_SECRET=newcms-dev-secret-change-in-production

# App
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000

# URL the web app proxies /api/* requests to (the NestJS API).
API_URL=http://localhost:3001

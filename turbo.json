{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": [
		"DB_HOST",
		"DB_PORT",
		"DB_NAME",
		"DB_USER",
		"DB_PASSWORD",
		"DB_MAX_CONNECTIONS",
		"REDIS_HOST",
		"REDIS_PORT",
		"AUTH_SECRET",
		"ADMIN_PASSWORD",
		"API_PORT",
		"WEB_PORT",
		"API_URL"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**"]
		},
		"dev": {
			"dependsOn": ["^build"],
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^build"]
		},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"test:watch": {
			"cache": false,
			"persistent": true
		},
		"clean": {
			"cache": false
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:seed": {
			"dependsOn": ["^build"],
			"cache": false
		}
	}
}

{
	"name": "@newcms/query-engine",
	"version": "0.2.0",
	"type": "module",
	"description": "Declarative query engine for NewCMS — type-safe content queries with taxonomy, meta, and date sub-queries",
	"license": "GPL-2.0-or-later",
	"repository": {
		"type": "git",
		"url": "https://github.com/durvs/newcms.git",
		"directory": "packages/query-engine"
	},
	"keywords": [
		"cms",
		"query",
		"drizzle",
		"postgres",
		"newcms"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "echo 'lint ok'",
		"clean": "rm -rf dist .turbo",
		"prepublishOnly": "pnpm run build"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.7"
	},
	"peerDependencies": {
		"@newcms/database": ">=0.0.2"
	},
	"devDependencies": {
		"@newcms/config": "workspace:*",
		"@newcms/database": "workspace:*",
		"@types/node": "^22.15.3",
		"dotenv": "^16.5.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}

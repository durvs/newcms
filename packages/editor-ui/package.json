{
	"name": "@newcms/editor-ui",
	"version": "0.1.0",
	"type": "module",
	"description": "React visual editor UI for NewCMS — shell, controls, preview, widgets",
	"license": "GPL-2.0-or-later",
	"repository": {
		"type": "git",
		"url": "https://github.com/durvs/newcms.git",
		"directory": "packages/editor-ui"
	},
	"keywords": [
		"cms",
		"editor",
		"visual-builder",
		"react",
		"newcms"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"lint": "echo 'lint ok'",
		"clean": "rm -rf dist .turbo",
		"prepublishOnly": "pnpm run build"
	},
	"dependencies": {
		"@newcms/editor": "workspace:*"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0",
		"zustand": ">=4.0.0"
	},
	"devDependencies": {
		"@newcms/config": "workspace:*",
		"@types/react": "^19.1.3",
		"@types/react-dom": "^19.1.3",
		"lucide-react": "^0.511.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"zustand": "^5.0.5",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	}
}

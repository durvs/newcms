{
	"name": "@newcms/database",
	"version": "0.3.0",
	"type": "module",
	"description": "Database schema, object cache, and repositories for NewCMS",
	"license": "GPL-2.0-or-later",
	"repository": {
		"type": "git",
		"url": "https://github.com/durvs/newcms.git",
		"directory": "packages/database"
	},
	"keywords": [
		"cms",
		"database",
		"drizzle",
		"postgres",
		"redis",
		"cache",
		"newcms"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "echo 'lint ok'",
		"clean": "rm -rf dist .turbo",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx src/seed.ts",
		"prepublishOnly": "pnpm run build"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"ioredis": "^5.6.1",
		"postgres": "^3.4.7"
	},
	"devDependencies": {
		"@newcms/auth": "workspace:*",
		"@newcms/config": "workspace:*",
		"@types/node": "^22.15.3",
		"dotenv": "^16.5.0",
		"drizzle-kit": "^0.31.1",
		"tsup": "^8.5.1",
		"tsx": "^4.19.4",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}

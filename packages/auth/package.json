{
	"name": "@newcms/auth",
	"version": "0.2.0",
	"type": "module",
	"description": "Authentication, password hashing, sessions, nonces, and capabilities for NewCMS",
	"license": "GPL-2.0-or-later",
	"repository": {
		"type": "git",
		"url": "https://github.com/durvs/newcms.git",
		"directory": "packages/auth"
	},
	"keywords": [
		"cms",
		"auth",
		"bcrypt",
		"session",
		"nonce",
		"newcms"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "echo 'lint ok'",
		"clean": "rm -rf dist .turbo",
		"prepublishOnly": "pnpm run build"
	},
	"dependencies": {
		"bcrypt": "^6.0.0"
	},
	"peerDependencies": {
		"ioredis": ">=5.0.0"
	},
	"devDependencies": {
		"@newcms/config": "workspace:*",
		"@types/bcrypt": "^5.0.2",
		"@types/node": "^22.15.3",
		"ioredis": "^5.6.1",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}
